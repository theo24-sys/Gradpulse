# ==========================================
# GradPulse Environment Configuration
# ==========================================

# Core Django Settings
DEBUG=True
SECRET_KEY=replace-me-with-a-very-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database (PostgreSQL via Railway)
# If left empty, local SQLite will be used.
DATABASE_URL=postgres://user:password@host:port/dbname

# Redis (Celery Broker & Cache)
REDIS_URL=redis://default:password@host:port

# Cloudflare R2 / AWS S3 (django-storages)
AWS_ACCESS_KEY_ID=your_cloudflare_access_key
AWS_SECRET_ACCESS_KEY=your_cloudflare_secret_key
AWS_STORAGE_BUCKET_NAME=your_r2_bucket_name
AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Pusher (Realtime)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Mpesa Daraja
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_PASSKEY=...

# Resend (django-anymail)
RESEND_API_KEY=re_...
DEFAULT_FROM_EMAIL=GradPulse <hello@gradpulse.com>
