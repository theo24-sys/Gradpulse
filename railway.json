{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "configFile": "nixpacks.toml"
  },
  "deploy": {
    "startCommand": "/opt/venv/bin/gunicorn gradpulse.wsgi:application --log-file -",
    "releaseCommand": "/opt/venv/bin/python manage.py migrate --noinput"
  }
}
